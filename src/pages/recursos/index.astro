---
import Layout from "../../layouts/Layout.astro";
import Seccion from "../../components/Seccion.astro";
import Tarjeta from "../../components/Tarjeta.astro";

interface Recurso {
  ruta: string;
  titulo: string;
  descripcion: string;
}

// todos los paths de los .astro files en este directorio
const todosAstros = Object.entries(
  import.meta.glob("./*.astro", { eager: true }),
);

// los archivos astros que tengan lo necesario convertidos en recursos interface
const recursosAutom = todosAstros.flatMap(([ruta, archivo]) => {
  if (!archivo.titulo || !archivo.descripcion) return []; // omite los que no cumplan con lo necesario
  return [
    {
      ruta: "/recursos" + ruta.replace(".", "").replace(".astro", ""),
      titulo: archivo.titulo,
      descripcion: archivo.descripcion,
    },
  ];
});

// Unimos los recursos automáticos con los manuales que queramos agregar
const todosRecursos = [
  ...recursosAutom,
  {
    // Aquí podríamos agregar recursos manualmente si es necesario
    ruta: "/recursos/temario",
    titulo: "Temario",
    descripcion: "Consulta el temario para la preparación de la olimpiada.",
  },
];
---

<Layout>
  <div class="contenedor-recursos">
    <h1 class="titulo-seccion">Recursos</h1>

    <section class="carrusel">
      {
        todosRecursos.map(({ ruta, titulo, descripcion }) => (
          <a href={ruta} class="carrusel-item">
            <Tarjeta>
              <h2>{titulo}</h2>
              <p>{descripcion}</p>
            </Tarjeta>
          </a>
        ))
      }
    </section>
  </div>
</Layout>

<style>
  .contenedor-recursos {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem;
  }

  .titulo-seccion {
    color: var(--colorTexto);
    margin-bottom: 1.5rem;
  }

  .carrusel {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    padding-bottom: 2rem;

    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;

    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .carrusel::-webkit-scrollbar {
    display: none;
  }

  .carrusel-item {
    flex: 0 0 100%;
    max-width: 350px;
    scroll-snap-align: center;

    text-decoration: none;
    color: var(--colorTexto);
    transition: transform 0.3s ease;

    display: flex;
    flex-direction: column;
    align-items: stretch;
  }

  .carrusel-item :global(> *) {
    flex: 1;
    height: 100%;
  }

  .carrusel-item:hover {
    transform: translateY(-5px);
  }

  @media (min-width: 768px) {
    .carrusel-item {
      flex: 0 0 calc(50% - 1.5rem);
      scroll-snap-align: start;
    }
  }

  @media (min-width: 1024px) {
    .carrusel-item {
      flex: 0 0 calc(33.333% - 1.5rem);
    }
  }
</style>
