---
export const titulo = "Electromagnetismo";
export const descripcion =
  "La interacción fundamental entre las cargas eléctricas, los voltajes y los campos magnéticos.";
export const subtemas = [
  "Carga y Ley de Coulomb",
  "Campo Eléctrico",
  "Potencial Eléctrico y Voltaje",
  "Magnetismo",
  "Ley de Faraday (Inducción)",
];
import Layout from "../../../layouts/Layout.astro";
import Seccion from "../../../components/Seccion.astro";
---

<Layout>
  <main class="contenedor-tema">
    <h1>{titulo}</h1>
    <p class="intro">{descripcion}</p>

    <Seccion titulo="Titulo" />

    <Seccion titulo="Titulo" />

    <Seccion titulo="Titulo" />

    <Seccion titulo="Titulo" />
  </main>
</Layout>

<style>
  .contenedor-tema {
    padding: 2rem;
    max-width: 800px;
    margin: 0 auto;
  }
</style>
