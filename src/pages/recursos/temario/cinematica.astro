---
export const titulo = "Cinemática";
export const descripcion =
  "El estudio del movimiento puro sin importar qué lo causa.";
export const subtemas = [
  "Posición, Velocidad y Aceleración",
  "Caída Libre",
  "Tiro Parabólico",
  "MRU y MRUA",
];
import Layout from "../../../layouts/Layout.astro";
import Seccion from "../../../components/Seccion.astro";
---

<Layout>
  <main class="contenedor-tema">
    <h1>{titulo}</h1>
    <p class="intro">{descripcion}</p>

    <Seccion titulo="Titulo" />

    <Seccion titulo="Titulo" />

    <Seccion titulo="Titulo" />

    <Seccion titulo="Titulo" />
  </main>
</Layout>

<style>
  .contenedor-tema {
    padding: 2rem;
    max-width: 800px;
    margin: 0 auto;
  }
</style>
