---
export const titulo = "Vectores";
export const descripcion =
  "Cantidades que poseen magnitud y dirección, que explican fuerzas y trayectorias.";
export const subtemas = [
  "Diferencia entre Vector y Escalar",
  "Suma y Resta Vectorial",
  "Componentes Geométricos y Analíticos",
];
import Layout from "../../../layouts/Layout.astro";
import Seccion from "../../../components/Seccion.astro";
---

<Layout>
  <main class="contenedor-tema">
    <h1>{titulo}</h1>
    <p class="intro">{descripcion}</p>

    <Seccion titulo="Titulo" />

    <Seccion titulo="Titulo" />

    <Seccion titulo="Titulo" />

    <Seccion titulo="Titulo" />
  </main>
</Layout>

<style>
  .contenedor-tema {
    padding: 2rem;
    max-width: 800px;
    margin: 0 auto;
  }
</style>
