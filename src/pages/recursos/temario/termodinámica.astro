---
export const titulo = "Termodinámica";
export const descripcion =
  "Estudio del calor, la temperatura y las leyes de la termodinámica.";
export const subtemas = [
  "Calor y Temperatura",
  "Modelo de Gas Ideal",
  "Variables de Estado",
  "Las 4 Leyes de la Termodinámica",
];
0;

import Layout from "../../../layouts/Layout.astro";
import Seccion from "../../../components/Seccion.astro";
---

<Layout>
  <main class="contenedor-tema">
    <h1>{titulo}</h1>
    <p class="intro">{descripcion}</p>

    <Seccion titulo="Calor y temperatura">
      <p>La energía no se crea ni se destruye...</p>
    </Seccion>

    <Seccion titulo="Modelo de Gas Ideal">
      <p>El desorden del universo siempre aumenta...</p>
    </Seccion>

    <Seccion titulo="Variables de estado">
      <p>El cero absoluto es inalcanzable...</p>
    </Seccion>

    <Seccion titulo="Las 4 Leyes de la Termodinámica">
      <p>La entropía de un cristal perfecto es cero a 0 K...</p>
    </Seccion>
  </main>
</Layout>

<style>
  .contenedor-tema {
    padding: 2rem;
    max-width: 800px;
    margin: 0 auto;
  }
</style>
