---
export const titulo = "Energía";
export const descripcion =
  "Trabajo, energía y potencia. Un enfoque alternativo (y a veces más sencillo) para resolver sistemas físicos.";
export const subtemas = [
  "Trabajo y Energía",
  "Energía Cinética y Potencial",
  "Conservación de la Energía",
  "Potencia y eficiencia",
];
import Layout from "../../../layouts/Layout.astro";
import Seccion from "../../../components/Seccion.astro";
---

<Layout>
  <main class="contenedor-tema">
    <h1>{titulo}</h1>
    <p class="intro">{descripcion}</p>

    <Seccion titulo="Titulo" />

    <Seccion titulo="Titulo" />

    <Seccion titulo="Titulo" />

    <Seccion titulo="Titulo" />
  </main>
</Layout>

<style>
  .contenedor-tema {
    padding: 2rem;
    max-width: 800px;
    margin: 0 auto;
  }
</style>
