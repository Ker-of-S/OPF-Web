---
export const titulo = "Mecánica de fluidos";
export const descripcion =
  "Estudio del comportamiento de los fluidos en reposo y en movimiento.";
export const subtemas = [
  "Propiedades de los Fluidos",
  "Presión y Ecuación de Bernoulli",
  "Ecuación de Continuidad",
  "Viscosidad y Fricción en Fluidos",
  "Principio de Arquímedes y Flotabilidad",
  "Principio de Pascal y Aplicaciones",
];
import Layout from "../../../layouts/Layout.astro";
import Seccion from "../../../components/Seccion.astro";
---

<Layout>
  <main class="contenedor-tema">
    <h1>{titulo}</h1>
    <p class="intro">{descripcion}</p>

    <Seccion titulo="Titulo" />

    <Seccion titulo="Titulo" />

    <Seccion titulo="Titulo" />

    <Seccion titulo="Titulo" />
  </main>
</Layout>

<style>
  .contenedor-tema {
    padding: 2rem;
    max-width: 800px;
    margin: 0 auto;
  }
</style>
